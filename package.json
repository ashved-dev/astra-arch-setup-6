{
  "name": "astra-arch-setup-6",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "api": "node src/api/server.js",
    "dev:stack": "sh -c 'HOST=127.0.0.1 PORT=4174 npm run api >/tmp/astra-arch-setup-6-api.log 2>&1 & npm run dev -- --host 127.0.0.1 --port 4173'",
    "db:migrate": "node scripts/db-migrate.mjs",
    "start": "node src/runtime/server.js",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "tsc --noEmit",
    "test": "node --test test/*.test.mjs",
    "e2e": "playwright test",
    "lint:e2e": "playwright test e2e/ci-workflow.spec.js e2e/bootstrap-app.spec.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.24",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^5.4.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "dependencies": {
    "pg": "^8.13.3"
  }
}
